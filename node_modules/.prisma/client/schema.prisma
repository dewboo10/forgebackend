// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int     @id @default(autoincrement())
  telegramId    BigInt  @unique
  username      String?
  firstName     String?
  lastName      String?
  photoUrl      String?
  walletAddress String?

  // Mining
  balance         Float     @default(0)
  totalMined      Float     @default(0)
  miningStartedAt DateTime?
  lastClaimAt     DateTime  @default(now())

  // Upgrades stored as JSON: { "1": 2, "3": 1 } = upgradeId: level
  upgrades Json @default("{}")

  // Purchases: array of item IDs
  purchased String[] @default([])

  // Referrals
  referralCode String @unique
  referredById Int?
  referredBy   User?  @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[] @relation("Referrals")

  // Streak
  streakCount  Int       @default(0)
  lastStreakAt DateTime?

  // Trust score (0-100)
  trustScore Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  purchases        Purchase[]
  missionProgress  MissionProgress[]
  circleMembers    CircleMember[]    @relation("CircleOwner")
  circleOf         CircleMember[]    @relation("CircleMember")
  sentRequests     CircleRequest[]   @relation("RequestSender")
  receivedRequests CircleRequest[]   @relation("RequestReceiver")
  dailyRewards     DailyReward[]
  sessions         MiningSession[]
}

model MiningSession {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  startedAt   DateTime  @default(now())
  stoppedAt   DateTime?
  earnedFRG   Float     @default(0)
  rateAtStart Float
}

model Purchase {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  itemId      String
  priceTON    Float
  txHash      String?   @unique
  boc         String?
  status      String    @default("pending") // pending | confirmed | failed
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
}

model MissionProgress {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  missionId       String
  checkpointIndex Int
  claimedAt       DateTime @default(now())

  @@unique([userId, missionId, checkpointIndex])
}

model CircleMember {
  id       Int      @id @default(autoincrement())
  ownerId  Int
  owner    User     @relation("CircleOwner", fields: [ownerId], references: [id])
  memberId Int
  member   User     @relation("CircleMember", fields: [memberId], references: [id])
  verified Boolean  @default(false)
  addedAt  DateTime @default(now())

  @@unique([ownerId, memberId])
}

model CircleRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("RequestSender", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("RequestReceiver", fields: [receiverId], references: [id])
  status     String   @default("pending") // pending | accepted | declined
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}

model DailyReward {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  day       Int
  reward    Float
  claimedAt DateTime @default(now())
}
