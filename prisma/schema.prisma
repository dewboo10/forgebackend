generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  telegramId       BigInt            @unique
  username         String?
  firstName        String?
  lastName         String?
  photoUrl         String?
  walletAddress    String?
  balance          Float             @default(0)
  totalMined       Float             @default(0)
  miningStartedAt  DateTime?
  lastClaimAt      DateTime          @default(now())
  upgrades         Json              @default("{}")
  purchased        String[]          @default([])
  referralCode     String            @unique
  referredById     Int?
  streakCount      Int               @default(0)
  lastStreakAt     DateTime?
  trustScore       Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  circleOf         CircleMember[]    @relation("CircleMember")
  circleMembers    CircleMember[]    @relation("CircleOwner")
  receivedRequests CircleRequest[]   @relation("RequestReceiver")
  sentRequests     CircleRequest[]   @relation("RequestSender")
  dailyRewards     DailyReward[]
  sessions         MiningSession[]
  missionProgress  MissionProgress[]
  purchases        Purchase[]
  referredBy       User?             @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]            @relation("Referrals")
}

model MiningSession {
  id          Int       @id @default(autoincrement())
  userId      Int
  startedAt   DateTime  @default(now())
  stoppedAt   DateTime?
  earnedFRG   Float     @default(0)
  rateAtStart Float
  user        User      @relation(fields: [userId], references: [id])
}

model Purchase {
  id          Int       @id @default(autoincrement())
  userId      Int
  itemId      String
  priceTON    Float
  txHash      String?   @unique
  boc         String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
  user        User      @relation(fields: [userId], references: [id])
}

model MissionProgress {
  id              Int      @id @default(autoincrement())
  userId          Int
  missionId       String
  checkpointIndex Int
  claimedAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, missionId, checkpointIndex])
}

model CircleMember {
  id       Int      @id @default(autoincrement())
  ownerId  Int
  memberId Int
  verified Boolean  @default(false)
  addedAt  DateTime @default(now())
  member   User     @relation("CircleMember", fields: [memberId], references: [id])
  owner    User     @relation("CircleOwner", fields: [ownerId], references: [id])

  @@unique([ownerId, memberId])
}

model CircleRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  receiver   User     @relation("RequestReceiver", fields: [receiverId], references: [id])
  sender     User     @relation("RequestSender", fields: [senderId], references: [id])

  @@unique([senderId, receiverId])
}

model DailyReward {
  id        Int      @id @default(autoincrement())
  userId    Int
  day       Int
  reward    Float
  claimedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
